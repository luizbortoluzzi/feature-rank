# ============================================================
# Feature Rank — environment variable reference
# Copy this file to .env and fill in all values.
# NEVER commit the real .env file to git.
# ============================================================

# ── MySQL Database ──────────────────────────────────────────
# Used by both the MySQL container and the Django backend.

MYSQL_DATABASE=feature_rank
MYSQL_USER=feature_rank_user
# SECRET — change this for every environment
MYSQL_PASSWORD=
# SECRET — change this for every environment; root is used by healthchecks and init scripts
MYSQL_ROOT_PASSWORD=

# ── Django Backend ──────────────────────────────────────────

# SECRET — generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# Comma-separated list of allowed hostnames (no spaces)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated origins the browser may send cross-origin requests from
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── Frontend ────────────────────────────────────────────────

# Base URL the browser uses to reach the Django API.
# Development: http://localhost:8000 (Vite dev server proxy handles this)
# Production:  ""  (empty string — nginx proxies /api/ on the same origin)
VITE_API_BASE_URL=http://localhost:8000
