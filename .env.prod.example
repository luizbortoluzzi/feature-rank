# ============================================================
# Feature Rank — PRODUCTION environment variable reference
# Copy this file to .env.prod and fill in ALL values.
# NEVER commit .env.prod to git.
# ============================================================
# Usage:
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
# ============================================================

# ── Domain ──────────────────────────────────────────────────
# The public hostname of this application.
# DNS A record must point to this VM's public IP before first deploy.
# Traefik uses this to route traffic and request a TLS certificate.
DOMAIN=feature-rank.yourdomain.com

# ── Let's Encrypt ───────────────────────────────────────────
# Email address for certificate expiry notifications.
# Required by Let's Encrypt ACME protocol.
ACME_EMAIL=you@example.com

# ── Traefik dashboard ───────────────────────────────────────
# HTTP basic auth credentials for the Traefik dashboard.
# Accessible at: https://traefik.{DOMAIN}
# Generate with:
#   docker run --rm httpd:alpine htpasswd -nbB admin 'your-password' \
#     | sed 's/\$\$/\$/g'
# The dollar signs must be doubled in .env.prod to avoid shell expansion.
# Example value: admin:$$2y$$05$$...hashed...
TRAEFIK_DASHBOARD_USERS=admin:$$2y$$05$$replacethiswitharealhashedpassword

# ── MySQL Database ──────────────────────────────────────────
MYSQL_DATABASE=feature_rank
MYSQL_USER=feature_rank_user
# SECRET — use a strong random password (min 24 chars)
# Generate: openssl rand -hex 24
MYSQL_PASSWORD=
# SECRET — root password for admin operations and healthchecks
MYSQL_ROOT_PASSWORD=

# ── Django Backend ──────────────────────────────────────────
# SECRET — generate with:
#   python3 -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=
